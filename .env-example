# Copy to `.env` (git-ignored) and fill in. Never commit real secrets.
# Used by later phases (LLM client, Gmail reporter); the playable core needs none.

# --- LLM provider (choose one approach; see PRD §N-03) ---
LLM_PROVIDER=cloud          # cloud | ollama | hybrid
LLM_API_KEY=
LLM_MODEL=

# Local Ollama (when LLM_PROVIDER=ollama/hybrid)
OLLAMA_BASE_URL=http://127.0.0.1:11434

# --- Gmail reporter (Phase 8) ---
# OAuth2 desktop client; credentials.json/token.json are git-ignored, not here.
REPORT_RECIPIENT=rmisegal+uoh26b@gmail.com
