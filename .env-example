# =============================================================================
# marl-cop-thief — SECRET PLACEHOLDERS (.env-example)
# -----------------------------------------------------------------------------
# Guidelines §7.4: NEVER commit real secrets. Copy this file to `.env` (which is
# git-ignored) and fill in the real values. Secrets are read ONLY via
# os.environ.get(...) — never hardcoded in source. `.env` is loaded at startup.
# Rotate keys periodically; grant least privilege; revoke on any suspicion.
# =============================================================================

# --- LLM PROVIDERS (Gatekeeper Dual-LLM failover; see config/setup.json) ------

# Primary LLM provider. Obtain from https://platform.deepseek.com/api_keys
# Used by llm_routing.primary (model: deepseek-chat). Plain httpx calls — no SDK.
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# Fallback LLM provider. Obtain from https://console.anthropic.com/settings/keys
# Used by llm_routing.fallback (model: claude-3-5-sonnet-20241022) on failover.
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# --- MCP SERVER TOKENS (revocable bearer tokens; see config/setup.json) -------

# Bearer token authorizing calls to the COP cloud MCP server
# (https://cop-mcp.prefect.run). Must be revocable; rotate on exposure.
COP_MCP_TOKEN=cop-mcp-bearer-token-here

# Bearer token authorizing calls to the THIEF cloud MCP server
# (https://thief-mcp.prefect.run). Must be revocable; rotate on exposure.
THIEF_MCP_TOKEN=thief-mcp-bearer-token-here

# --- GMAIL / GOOGLE OAUTH2 (Desktop client; scope: gmail.modify only) ---------

# Filesystem path to the OAuth2 Desktop client secrets downloaded from the
# Google Cloud Console and renamed to credentials.json. This file AND the
# generated token.json are git-ignored. ZERO passwords are ever stored.
GMAIL_CREDENTIALS_PATH=./credentials.json
